<Window x:Class="Czyscik.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Czyścik — Pro" Height="560" Width="960" MinHeight="480" MinWidth="720">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="6" VerticalAlignment="Top">
            <TextBlock Text="Obszary do czyszczenia" FontWeight="Bold" Margin="0,0,0,8" />
            <CheckBox x:Name="chkTemp" Content="%TEMP% (profil użytkownika)" IsChecked="True" />
            <CheckBox x:Name="chkWindowsTemp" Content="C:\\Windows\\Temp" IsChecked="True" />
            <CheckBox x:Name="chkWindowsUpdate" Content="Wyczyść Windows Update (SoftwareDistribution\\Download)" IsChecked="False" />
            <CheckBox x:Name="chkPrefetch" Content="Prefetch" IsChecked="False" />
            <CheckBox x:Name="chkSystemLogs" Content="Czyszczenie logów systemowych (Windows Logs) - zaawansowane" IsChecked="False" />
            <CheckBox x:Name="chkThumbs" Content="Thumbnails cache" IsChecked="False" />
            <CheckBox x:Name="chkRecycle" Content="Opróżnij Kosz" IsChecked="False" />
            <CheckBox x:Name="chkBrowsers" Content="Cache przeglądarek (Chrome/Edge)" IsChecked="True" />

            <Separator Margin="0,8" />
            <CheckBox x:Name="chkTurbo" Content="Turbo Cleaner (preset)" Margin="0,4" />
            <CheckBox x:Name="chkDryRun" Content="Suchy bieg (Preview)" Margin="0,4" />
            <CheckBox x:Name="chkConfirmEach" Content="Potwierdzenie przed czyszczeniem każdego katalogu" Margin="0,4" />
            <WrapPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Left" ItemHeight="30" ItemWidth="110">
                <Button x:Name="btnStart" Content="Start" Width="110" />
                <Button x:Name="btnPreview" Content="Preview" Width="110" Margin="6,0,0,0" />
                    <Button x:Name="btnCheckUpdates" Content="Sprawdź aktualizacje" Width="160" Margin="6,0,0,0" />
                <Button x:Name="btnCancel" Content="Anuluj" Width="110" Margin="6,0,0,0" IsEnabled="False" />
            </WrapPanel>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="6" VerticalAlignment="Top">
            <TextBlock Text="Ścieżki (wybierz lub dodaj własne)" FontWeight="Bold" />
            <ListBox x:Name="lstPaths" Margin="0,6" VerticalAlignment="Stretch" MinHeight="140" MaxHeight="300" />
            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtNewPath" Grid.Column="0" HorizontalAlignment="Stretch" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0">
                    <Button x:Name="btnAdd" Content="Dodaj" Width="70" Margin="0,0,6,0" />
                    <Button x:Name="btnPick" Content="Wybierz..." Width="90" Margin="0,0,6,0" />
                    <Button x:Name="btnRemove" Content="Usuń" Width="70" Margin="0,0,6,0" />
                    <Button x:Name="btnDetails" Content="Pokaż pliki" Width="100" />
                    <Button x:Name="btnAutostart" Content="Autostart" Width="90" Margin="6,0,0,0" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Postęp" FontWeight="Bold" Margin="0,8,0,0" />
            <ProgressBar x:Name="progressBar" Height="20" Minimum="0" Maximum="100" Margin="0,6" />
            <TextBlock x:Name="lblStatus" Text="Gotowy" Margin="0,6" />
            <TextBlock x:Name="lblBefore" Text="Wolne przed: -" Margin="0,6" />
            <TextBlock x:Name="lblAfter" Text="Wolne po: -" Margin="0,6" />
            <TextBlock x:Name="lblFreed" Text="Odzyskane: 0 B" Margin="0,6" />
            <TextBlock x:Name="lblLog" Text="Log:" Margin="0,6" />
            <DockPanel>
                <Button x:Name="btnRefreshLog" Content="Odśwież log" Width="100" DockPanel.Dock="Left" />
            </DockPanel>
            <TextBox x:Name="txtLog" Height="160" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Margin="0,6" />
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
