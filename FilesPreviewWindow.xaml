<Window x:Class="Czyscik.FilesPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Podgląd plików" Height="500" Width="700">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtHeader" FontWeight="Bold" />
        <ListBox x:Name="lstFiles" Grid.Row="1" HorizontalContentAlignment="Left" />

        <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <DockPanel>
                <TextBlock x:Name="lblSummary" VerticalAlignment="Center" DockPanel.Dock="Left" />
                <TextBlock x:Name="lblFreedPreview" VerticalAlignment="Center" DockPanel.Dock="Right" Margin="12,0,0,0" />
            </DockPanel>
            <ProgressBar x:Name="progressBarPreview" Height="16" Minimum="0" Maximum="100" Margin="0,6,0,0" />
            <TextBlock x:Name="lblStatusPreview" Margin="0,6,0,0" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                <Button x:Name="btnDeleteHere" Content="Usuń pliki (potwierdź)" Width="160" Margin="6,0,0,0" />
                <Button x:Name="btnCancelDelete" Content="Anuluj" Width="80" Margin="6,0,0,0" />
                <Button x:Name="btnClose" Content="Zamknij" Width="80" Margin="6,0,0,0" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
